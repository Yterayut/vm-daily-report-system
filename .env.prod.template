# Production baseline template (do not commit real secrets)

# Core endpoints
ZABBIX_URL=http://your-zabbix-server/zabbix/api_jsonrpc.php
ZABBIX_USER=replace_me
ZABBIX_PASS=replace_me

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
EMAIL_USERNAME=replace_me@example.com
EMAIL_PASSWORD=replace_me_app_password
SENDER_EMAIL=replace_me@example.com
TO_EMAILS=ops@example.com

# Runtime policy flags (strict)
ENABLE_LEGACY_EMAIL_FIX=false
ENABLE_NEW_SERVICE_SOURCE=true
ENABLE_STRICT_ENV_GUARD=true
# Temporary exception for strict mode when using placeholder/default Zabbix creds
ALLOW_DEFAULT_ZABBIX_CREDENTIALS=false

PRODUCTION_POLICY_REQUIRED=true
CREDENTIAL_HARDENING_REQUIRED=true
ZABBIX_PREFLIGHT_REQUIRED=true
SMTP_PREFLIGHT_REQUIRED=true

EMAIL_DRY_RUN=false

# Optional gate failure alert
ENABLE_GATE_FAILURE_ALERTS=false
GATE_ALERT_EMAIL=ops@example.com

# Retention policy
RETENTION_DAYS=90
RETENTION_APPLY=false
