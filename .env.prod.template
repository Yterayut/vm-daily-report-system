# Production Environment Template (No real secrets in this file)
# Copy to .env on production host and set real secret values.

# Zabbix Configuration
ZABBIX_URL=https://your-zabbix-server/zabbix/api_jsonrpc.php
ZABBIX_USER=your_service_account
ZABBIX_PASS=your_strong_service_password
ZABBIX_TIMEOUT=30
ZABBIX_VERIFY_SSL=true

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
EMAIL_USERNAME=your_sender@company.com
EMAIL_PASSWORD=your_app_password
SENDER_EMAIL=your_sender@company.com
SENDER_NAME=VM Monitoring System
TO_EMAILS=ops-team@company.com
CC_EMAILS=
BCC_EMAILS=
EMAIL_DRY_RUN=false

# Report Paths
REPORT_TEMPLATE_DIR=templates
REPORT_OUTPUT_DIR=output
REPORT_STATIC_DIR=static

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Feature Flags (production baseline)
ENABLE_LEGACY_EMAIL_FIX=false
ENABLE_NON_SIMPLE_MODE=false
ENABLE_NEW_SERVICE_SOURCE=true
ENABLE_STRICT_ENV_GUARD=true

# Gate enforcement
ZABBIX_PREFLIGHT_REQUIRED=true
CREDENTIAL_HARDENING_REQUIRED=true
PRODUCTION_POLICY_REQUIRED=true
SMTP_PREFLIGHT_REQUIRED=true

# Optional LINE integration
LINE_NOTIFICATIONS_ENABLED=false
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# Optional gate failure alert
ENABLE_GATE_FAILURE_ALERTS=false
GATE_ALERT_EMAIL=ops@example.com

# Retention policy
RETENTION_DAYS=90
RETENTION_APPLY=false
