# Copy this file to .env and configure your settings

# =============================================================================
# VM Daily Report Environment Configuration Template
# =============================================================================

# Zabbix Configuration
ZABBIX_URL=http://your-zabbix-server/zabbix/api_jsonrpc.php
ZABBIX_USER=your_username  
ZABBIX_PASS=your_password
ZABBIX_TIMEOUT=30
ZABBIX_VERIFY_SSL=false

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Gmail App Password (not regular password)
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
SENDER_EMAIL=your_email@gmail.com
SENDER_NAME=VM Monitoring System
REPLY_TO_EMAIL=your_email@gmail.com

# Recipients (comma-separated)
TO_EMAILS=recipient1@domain.com,recipient2@domain.com
CC_EMAILS=
BCC_EMAILS=

# Email Retry Settings
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=5

# =============================================================================
# LINE Bot Configuration (Optional)
# =============================================================================
# Get these from LINE Developers Console
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_USER_ID=your_line_user_id

# =============================================================================
# Alert Thresholds Configuration
# =============================================================================
# CPU Alert Thresholds (percentage)
CPU_WARNING_THRESHOLD=70
CPU_CRITICAL_THRESHOLD=85

# Memory Alert Thresholds (percentage)  
MEMORY_WARNING_THRESHOLD=75
MEMORY_CRITICAL_THRESHOLD=90

# Disk Alert Thresholds (percentage)
DISK_WARNING_THRESHOLD=80
DISK_CRITICAL_THRESHOLD=90

# =============================================================================
# Alert Channel Configuration
# =============================================================================
# Which channels to use for different alert levels (comma-separated)
# Available channels: email, line, slack, teams
INFO_ALERT_CHANNELS=email
WARNING_ALERT_CHANNELS=email,line
CRITICAL_ALERT_CHANNELS=email,line
EMERGENCY_ALERT_CHANNELS=email,line

# Alert Rate Limiting (minutes between similar alerts)
ALERT_RATE_LIMIT=15

# =============================================================================
# Report Configuration
# =============================================================================
REPORT_TEMPLATE_DIR=templates
REPORT_OUTPUT_DIR=output
REPORT_STATIC_DIR=static
REPORT_PAGE_SIZE=A4
REPORT_MARGINS=2cm

# Company Branding
COMPANY_LOGO=your_company
COMPANY_NAME=Your Company Name
DEPARTMENT_NAME=IT Department

# =============================================================================
# Logging Configuration  
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# =============================================================================
# Progressive Rollout / Gate Flags
# =============================================================================
ENABLE_NEW_SERVICE_SOURCE=false
ENABLE_STRICT_ENV_GUARD=false
ENABLE_LEGACY_EMAIL_FIX=false
# Temporary exception for strict mode when using placeholder/default Zabbix creds
ALLOW_DEFAULT_ZABBIX_CREDENTIALS=false

PRODUCTION_POLICY_REQUIRED=false
CREDENTIAL_HARDENING_REQUIRED=false
ZABBIX_PREFLIGHT_REQUIRED=false
SMTP_PREFLIGHT_REQUIRED=false

# If true, email sending should stay in dry-run mode
EMAIL_DRY_RUN=true

# Gate failure alert (optional)
ENABLE_GATE_FAILURE_ALERTS=false
GATE_ALERT_EMAIL=

# Artifact retention policy
RETENTION_DAYS=90
RETENTION_APPLY=false
